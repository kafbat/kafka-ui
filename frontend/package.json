    "overrides": {
      "rimraf>glob": "11.1.0",
      "eslint-plugin-import>minimatch": "10.2.4",
      "eslint>minimatch": "10.2.4",
      "brace-expansion": "5.0.5",
      "@tootallnate/once@<3.0.1": "3.0.1",
      "fast-uri@<3.1.2": "3.1.2",
      "json-schema-faker>jsonpath-plus": "10.4.0"
    },
    "peerDependencyRules": {
      "allowedVersions": {
        "eslint": "9.39.3",
        "@typescript-eslint/parser": "8.39.0",
        "@typescript-eslint/eslint-plugin": "8.39.0"
      }
    }
  },
  "packageManager": "pnpm@10.26.1"
}
