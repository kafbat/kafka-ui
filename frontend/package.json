  "scripts": {
    "start": "vite",
    "dev": "vite",
    "compile": "pnpm gen:sources && tsc --noEmit",
    "gen:sources": "rimraf ./src/generated-sources && cd ../contract-typespec/api && pnpm install && pnpm build && cd ../../frontend  && openapi-generator-cli generate",
    "build": "pnpm gen:sources && tsc --noEmit && vite build",
    "preview": "vite preview",
    "lint": "eslint \"src/**/*.{ts,tsx}\"",
    "lint:fix": "eslint \"src/**/*.{ts,tsx}\" --fix",
    "lint:CI": "eslint \"src/**/*.{ts,tsx}\" --max-warnings=0",
    "test": "jest --watch",
    "test:coverage": "jest --watchAll --coverage",
    "test:CI": "CI=true pnpm test:coverage --ci --testResultsProcessor=\"jest-sonar-reporter\" --watchAll=false",
    "tsc": "tsc --pretty --noEmit",
    "deadcode": "ts-prune -i src/generated-sources"
  },
  "devDependencies": {
    "@jest/types": "29.6.3",
    "@openapitools/openapi-generator-cli": "2.31.0",
